{
  "manifest_version": 3,
  "name": "BookView",
  "version": "1.0.0",
  "description": "Read any webpage like an open book — dual-panel view with synchronized scrolling.",

  "permissions": [
    "scripting",
    "activeTab",
    "tabs",
    "storage"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Smart Dual Viewer ON / OFF",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_page": "options.html",

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Ctrl+Shift+S"
      },
      "description": "Toggle BookView ON/OFF"
    }
  }
}
